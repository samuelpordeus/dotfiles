{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:hexdocs.pm)",
      "mcp__ide__getDiagnostics",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(mix:*)",
      "Bash(MIX_ENV=test mix:*)",
      "Bash(MIX_ENV=dev mix:*)",
      "Bash(source:*)",
      "Bash(python3:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(chmod:*)",
      "Bash(xargs:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(pwd)",
      "Bash(which:*)",
      "Bash(env:*)",
      "Bash(yarn:*)",
      "Bash(brew:*)",
      "Bash(curl:*)",
      "Bash(jq:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(cut:*)",
      "Bash(tr:*)",
      "Bash(diff:*)",
      "Bash(set:*)",
      "Bash(direnv:*)",
      "Bash(asdf:*)",
      "Bash(iex:*)",
      "Bash(psql:*)",
      "Bash(pg_isready:*)",
      "Bash(terminal-notifier:*)",
      "Bash(lsof:*)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/dotfiles/claude/notify.sh 'Needs approval' 'Waiting for your input'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/dotfiles/claude/notify.sh 'Work complete' 'Ready for review'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/dotfiles/claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "elixir-lsp@claude-code-elixir": true,
    "mix-format@claude-code-elixir": true,
    "mix-compile@claude-code-elixir": true,
    "elixir@claude-code-elixir": true,
    "linear@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "playwright@claude-plugins-official": false
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  },
  "effortLevel": "medium",
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true
}
